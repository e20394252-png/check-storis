generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  telegram_id BigInt   @unique
  username    String?
  first_name  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  registrations Registration[]
  wallet        UserWallet?
}

model Organizer {
  id           String          @id @default(uuid())
  telegram_id  BigInt?         @unique
  username     String?
  first_name   String?
  photo_url    String?
  login        String?         @unique
  password     String?
  status       OrganizerStatus @default(PENDING)
  isSuperAdmin Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  events  Event[]
  balance OrganizerBalance?
}

enum OrganizerStatus {
  PENDING
  APPROVED
  REJECTED
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String?
  date        DateTime?
  location    String?
  repostUrl   String?
  imageUrl      String?   @db.Text
  price         Int?
  discountPrice Int?
  isActive      Boolean   @default(true)
  organizerId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // === Платный репост ===
  isPaidRepost     Boolean  @default(false)
  repostRewardUsdt Float?                     // оплата за 1 репост (USDT)
  repostsNeeded    Int?                       // сколько репостов нужно
  repostsFilled    Int      @default(0)       // сколько уже одобрено
  campaignBudget   Float?                     // бюджет без комиссии (USDT)
  campaignTotal    Float?                     // бюджет + 20% комиссия (USDT)
  campaignStatus   String?                    // null | 'draft' | 'pending_payment' | 'active' | 'paused' | 'completed'
  invoiceId        String?                    // CryptoBot Invoice ID
  invoiceUrl       String?                    // URL для оплаты

  organizer       Organizer?       @relation(fields: [organizerId], references: [id])
  registrations   Registration[]
  paymentRequests PaymentRequest[]
}

model Registration {
  id        String             @id @default(uuid())
  userId    String
  eventId   String
  status    RegistrationStatus @default(PENDING)
  proofUrl  String?
  storyUrl  String?
  adminNote String?
  paidAmount Float?            // USDT начислено юзеру (null = бесплатное)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

model PaymentRequest {
  id          String   @id @default(uuid())
  eventId     String
  eventTitle  String
  price       Int
  paymentType String   // 'full' | 'discount'
  telegramId  BigInt
  firstName   String?
  username    String?
  status      String   @default("new") // 'new' | 'processed'
  createdAt   DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
}

// === Платные репосты: кошельки и выводы ===

model UserWallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  balance     Float    @default(0)      // USDT доступно к выводу
  totalEarned Float    @default(0)      // всего заработано
  totalPaid   Float    @default(0)      // всего выведено
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals Withdrawal[]
}

model Withdrawal {
  id         String   @id @default(uuid())
  walletId   String
  amount     Float                           // USDT
  status     String   @default("pending")    // pending | completed | failed
  transferId String?                         // CryptoBot transfer_id
  error      String?                         // ошибка при неудаче
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  wallet     UserWallet @relation(fields: [walletId], references: [id])
}

model OrganizerBalance {
  id             String   @id @default(uuid())
  organizerId    String   @unique
  balance        Float    @default(0)   // USDT — остаток
  totalDeposited Float    @default(0)   // всего внесено
  totalSpent     Float    @default(0)   // всего потрачено на выплаты
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizer      Organizer @relation(fields: [organizerId], references: [id])
}
